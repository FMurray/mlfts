# Databricks MLflow Configuration
# Copy this file to .env and fill in your actual values
# Never commit the actual .env file to version control!

# Databricks Workspace URL
# Example: https://your-workspace.cloud.databricks.com
DATABRICKS_HOST=

# Databricks Personal Access Token or Service Principal Token
# Create a token in: Workspace > User Settings > Access Tokens
DATABRICKS_TOKEN=

# Unity Catalog Configuration
CATALOG_NAME=main
SCHEMA_NAME=ml_traces

# MLflow Experiment Name
# Use hierarchical naming: /Users/your.email@company.com/project/experiment
EXPERIMENT_NAME=/Users/your.email@company.com/ml-traces-experiment

# Enable Unity Catalog for MLflow
MLFLOW_ENABLE_UNITY_CATALOG=true

# MLflow Tracking URI (usually same as DATABRICKS_HOST)
MLFLOW_TRACKING_URI=${DATABRICKS_HOST}

# Optional: Enable Claude Code MLflow tracing
MLFLOW_CLAUDE_TRACING_ENABLED=true

# Optional: Databricks Cluster ID (if running jobs programmatically)
# DATABRICKS_CLUSTER_ID=

# Optional: Service Principal Configuration (alternative to PAT)
# DATABRICKS_CLIENT_ID=
# DATABRICKS_CLIENT_SECRET=

# Optional: Additional MLflow Configuration
# MLFLOW_EXPERIMENT_ID=
# MLFLOW_RUN_ID=
